DATABASE_URL=postgres://coder@localhost/coder?host=/var/run/postgresql
REDIS_URL=redis://localhost:6379

# ストレージバックエンドを明示指定（省略時は自動検出）
# STORAGE_DRIVER=s3  # "s3" | "local"

# S3 バックエンド設定（すべて設定されている場合に自動選択）
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=hyperdrive
# S3_FORCE_PATH_STYLE=true

# ローカルバックエンド設定
LOCAL_STORAGE_PATH=./data/uploads
LOCAL_BASE_URL=http://localhost:3400
LOCAL_SIGNED_URL_SECRET=<32文字以上のランダム文字列>

# ベクトル検索 (Qdrant)
QDRANT_URL=http://qdrant.catarks.org:6333
QDRANT_API_KEY=<Qdrant APIキー>

# 画像キャプション生成（省略時は無効）
# CAPTION_DRIVER=gemini      # "gemini" | "local_http"
# GEMINI_API_KEY=<Gemini APIキー>           # CAPTION_DRIVER=gemini 時に必須
# CAPTION_LOCAL_URL=http://localhost:8500   # CAPTION_DRIVER=local_http 時（省略可）

# WebRTC ICE（合言葉 P2P 共有）
# STUN_URLS=stun:stun.l.google.com:19302
# TURN_URLS=turn:openrelay.metered.ca:443?transport=tcp
# TURN_USERNAME=<Metered ダッシュボードで取得>
# TURN_CREDENTIAL=<Metered ダッシュボードで取得>
# 詳細: docs/TURN_SETUP.md

# 合言葉共有: 同一ルームの同時受信者上限（v2 多重受信者・段階1以降）
# 既定 5。DoS 防止のため大きくしすぎないこと。
WATCHWORD_MAX_JOINERS=5
